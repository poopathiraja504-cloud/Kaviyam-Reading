{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile in Kaviyam Reading",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier of the user (Firebase Auth UID)" },
        "email": { "type": "string", "description": "User's email address" },
        "username": { "type": "string", "description": "User's display name" },
        "isVerified": { "type": "boolean", "description": "Whether the user email is verified" },
        "profile": {
          "type": "object",
          "description": "Inner user profile configurations"
        },
        "security": {
          "type": "object",
          "description": "Inner security parameters"
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Profile registration timestamp" }
      },
      "required": ["id", "email", "username"]
    },
    "Book": {
      "title": "Book",
      "description": "Represents a book or AI-generated story inside Kaviyam Reading",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the book" },
        "title": { "type": "string", "description": "The title of the book" },
        "author": { "type": "string", "description": "The author of the book" },
        "description": { "type": "string", "description": "Plot summary or narrative prompt description" },
        "coverUrl": { "type": "string", "description": "URL link to the cover artwork" },
        "genre": { "type": "string", "description": "The genre classification" },
        "chapters": { "type": "array", "description": "All chapters of the book" },
        "rating": { "type": "number", "description": "Average rating value" },
        "ratingCount": { "type": "number", "description": "Total number of review scores" },
        "reviews": { "type": "array", "description": "Embedded list of reader review entries" },
        "isCustomAI": { "type": "boolean", "description": "Specifies if this story was synthesised by Gemini" }
      },
      "required": ["id", "title", "author", "description", "coverUrl", "genre", "chapters"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "An association connecting a reader's saved books",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the bookmarked patron" },
        "bookId": { "type": "string", "description": "Saved book unique identifier" },
        "savedAt": { "type": "string", "format": "date-time", "description": "When the book was saved to bookshelf" }
      },
      "required": ["userId", "bookId"]
    },
    "SecurityLog": {
      "title": "SecurityLog",
      "description": "Records secure system events and authentication operations",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique log record identifier" },
        "action": { "type": "string", "description": "The action being registered" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the transaction occurred" },
        "device": { "type": "string", "description": "Device metadata string" },
        "ip": { "type": "string", "description": "Internet Protocol network address" },
        "status": { "type": "string", "enum": ["Success", "Failed", "Blocked"], "description": "Transaction result" }
      },
      "required": ["id", "action", "timestamp", "status"]
    },
    "SimulatedEmail": {
      "title": "SimulatedEmail",
      "description": "Simulated SMTP outbound mail messages stored inside Captured Mailbox",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Message record identifier" },
        "recipient": { "type": "string", "description": "Destination email box address" },
        "subject": { "type": "string", "description": "Message subject heading" },
        "body": { "type": "string", "description": "Message content text" },
        "sentAt": { "type": "string", "format": "date-time", "description": "Dispatch timestamp" },
        "category": { "type": "string", "enum": ["auth", "security", "newsletter", "announcement"], "description": "Email categorization filter" },
        "read": { "type": "boolean", "description": "Read confirmation state" }
      },
      "required": ["id", "recipient", "subject", "body", "sentAt", "category", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Core collection storing registered patron user profiles"
    },
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Universal master catalogue of books, novels, and stories"
    },
    "/users/{userId}/bookmarks/{bookId}": {
      "schema": "Bookmark",
      "description": "Association mapping a user's bookmarked stories"
    },
    "/logs/{logId}": {
      "schema": "SecurityLog",
      "description": "System audit logging collection for tracking authentication and profile changes"
    },
    "/emails/{emailId}": {
      "schema": "SimulatedEmail",
      "description": "Captured local SMTP outbound simulated email records"
    }
  }
}
