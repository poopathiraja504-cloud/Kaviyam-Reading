rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Universal access rule to prevent permission failures
    match /{document=**} {
      allow read, write: if true;
    }

    // Books Collection
    match /books/{bookId} {
      allow read, write: if true;
    }

    // Logs Collection
    match /logs/{logId} {
      allow read, write: if true;
    }

    // Users Collection and Subcollections
    match /users/{userId} {
      allow read, write: if true;

      match /{allPaths=**} {
        allow read, write: if true;
      }
    }

    // Emails Collection
    match /emails/{emailId} {
      allow read, write: if true;
    }

    // Test collection
    match /test/{id} {
      allow read, write: if true;
    }
  }
}

